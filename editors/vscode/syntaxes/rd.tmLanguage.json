{
  "name": "Rd",
  "scopeName": "source.rd",
  "patterns": [
    { "include": "#comment" },
    { "include": "#section-tag" },
    { "include": "#inline-tag" },
    { "include": "#escaped" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.percent.rd",
      "match": "%.*$"
    },
    "section-tag": {
      "name": "meta.section.rd",
      "begin": "(\\\\(?:alias|arguments|author|concept|description|details|docType|encoding|examples|format|keyword|name|note|references|seealso|section|source|title|usage|value|Sexpr))\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "keyword.other.section.rd" },
        "2": { "name": "punctuation.definition.section.begin.rd" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.section.end.rd" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#inline-tag" },
        { "include": "#escaped" },
        { "include": "#code-block" }
      ]
    },
    "inline-tag": {
      "name": "meta.inline-tag.rd",
      "begin": "(\\\\(?:code|dontrun|donttest|dontshow|testonly|emph|strong|pkg|file|email|url|href|link|linkS4class|var|env|option|command|dfn|cite|acronym|bold|samp|ifelse|if|out|R|cr|ldots|dots|tab|preformatted))\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "entity.name.tag.rd" },
        "2": { "name": "punctuation.definition.tag.begin.rd" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.tag.end.rd" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#inline-tag" },
        { "include": "#escaped" }
      ]
    },
    "code-block": {
      "name": "markup.raw.code.rd",
      "match": "\\\\code\\{[^}]*\\}"
    },
    "escaped": {
      "name": "constant.character.escape.rd",
      "match": "\\\\[{}\\\\%]"
    }
  }
}
